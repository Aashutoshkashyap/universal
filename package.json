{
  "name": "uesc-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck && npm run build",
    "prelighthouse": "node -e \"require('fs').mkdirSync('.lighthouse', { recursive: true })\"",
    "lighthouse": "lighthouse http://127.0.0.1:3000 --only-categories=performance,accessibility,best-practices,seo --output=json --output=html --output-path=.lighthouse/uesc-mobile",
    "prelighthouse:desktop": "node -e \"require('fs').mkdirSync('.lighthouse', { recursive: true })\"",
    "lighthouse:desktop": "lighthouse http://127.0.0.1:3000 --preset=desktop --only-categories=performance,accessibility,best-practices,seo --output=json --output=html --output-path=.lighthouse/uesc-desktop",
    "prelighthouse:agentic": "node -e \"require('fs').mkdirSync('.lighthouse', { recursive: true })\"",
    "lighthouse:agentic": "lighthouse http://127.0.0.1:3000 --config-path=./node_modules/lighthouse/core/config/agentic-browsing-config.js --only-categories=agentic-browsing --output=json --output=html --output-path=.lighthouse/uesc-agentic"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "lucide-react": "^1.17.0",
    "next": "^16.2.11",
    "postcss": "^8.5.15",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^16.2.11",
    "lighthouse": "^13.4.1",
    "typescript": "^5"
  },
  "overrides": {
    "postcss": "$postcss",
    "sharp": "0.35.3"
  }
}
